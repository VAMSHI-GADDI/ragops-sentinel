# RAGOps Sentinel environment example
# Copy to .env for local use. Never commit real secrets.

# LLM provider options: mock, bedrock, openai
LLM_PROVIDER=mock
LLM_MODEL_ID=mock-ragops-local
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# AWS Bedrock optional settings
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# OpenAI-compatible optional settings
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Local app settings
APP_ENV=local
